<%- layout('layouts/bolierplate') %>

<div class="row">
  <h1 class="text-center">New Campground</h1>
  <div class="col-6 offset-3">
    <form
      class="validated-form"
      action="/campgrounds"
      method="POST"
      novalidate
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label class="form-label" for="title">Campground Title</label>
        <input
          class="form-control"
          type="text"
          name="campground[title]"
          id="title"
          required
        />
      </div>

      <div class="mb-3">
        <label class="form-label" for="location">Location</label>
        <input
          class="form-control"
          type="text"
          name="campground[location]"
          id="location"
          required
        />
      </div>
      <!-- <div class="mb-3">
        <input type="file" multiple name="image" id="image" />
      </div> -->

      <div class="mb-3">
        <label class="form-label">Add images</label>

        <div id="drop-zone" class="drop-zone">
          <p>Drag & drop images here or click to select</p>

          <input type="file" multiple name="image" id="image" hidden />
        </div>

        <div id="file-list" class="file-list"></div>
        <div id="upload-error" class="upload-error"></div>
      </div>

      <div class="mb-3">
        <label class="form-label" for="price">Price</label>
        <div class="input-group">
          <span class="input-group-text">$</span>
          <input
            type="text"
            class="form-control"
            name="campground[price]"
            id="price"
            required
          />
        </div>
      </div>

      <div class="mb-3">
        <label for="description">Description</label>
        <textarea
          class="form-control"
          id="description"
          name="campground[description]"
          required
        ></textarea>
      </div>

      <div class="mb-3">
        <button class="btn btn-success" type="submit">Add Campground</button>
      </div>
    </form>
    <a href="/campgrounds">All Campgrounds</a>
  </div>
</div>
